# URL pública do site (usada em metadata, sitemap e robots)
NEXT_PUBLIC_SITE_URL=https://www.centraldepublicacoes.com.br

# Número de WhatsApp para redirecionamento pós-lead e botão flutuante.
# Formato: apenas dígitos, com DDI + DDD (ex.: 554832573500)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Webhook que recebe os leads validados enviados por app/api/leads/route.ts
# [CONFIRMAR COM A EMPRESA]
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Google Tag Manager (opcional)
NEXT_PUBLIC_GTM_ID=

# Meta Pixel (opcional)
NEXT_PUBLIC_META_PIXEL_ID=

# Google Ads — Conversion Tracking via gtag.js (opcional).
# Conversion ID (formato AW-XXXXXXXXX) e Conversion Label da ação de conversão
# "Lead [ORÇAMENTO]" criada na conta do Google Ads. Disparado em quote_form_success.
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Integração oficial com Google Places API para avaliações reais (opcional).
# Se não configurado, o sistema usa apenas o array estático em config/google-reviews.ts.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Link fixo para deixar avaliação no Google (CTA "Deixar uma avaliação no Google")
NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://g.page/r/Ce8evMwiD456EBM/review

# URL pública do perfil no Google Maps (CTA "Ver todas as avaliações no Google")
# Se vazio, esse CTA fica oculto. Valor padrão já definido em config/contact.ts.
NEXT_PUBLIC_GOOGLE_MAPS_PROFILE_URL=https://maps.app.goo.gl/dWEhvonwia8HTWV86
